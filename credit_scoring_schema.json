{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LoanApplicationSchema",
  "description": "Schema for validating complex credit scoring data",
  "type": "object",
  "required": ["applicationId", "applicant", "financialInfo", "assets"],
  "properties": {
    "applicationId": {
      "type": "string",
      "description": "Unique ID in format APP-YYYY-XXXXX",
      "pattern": "^APP-[0-9]{4}-[0-9]{5}$"
    },
    "applicant": {
      "type": "object",
      "required": ["personalInfo", "employment"],
      "properties": {
        "personalInfo": {
          "type": "object",
          "required": ["fullName", "email", "idNumber"],
          "properties": {
            "fullName": { "type": "string", "minLength": 3 },
            "email": { "type": "string", "format": "email" },
            "idNumber": { 
              "type": "string", 
              "pattern": "^[0-9]{16}$",
              "description": "Indonesian KTP number must be 16 digits"
            }
          }
        },
        "employment": {
          "type": "object",
          "required": ["companyName", "position", "yearsOfExperience"],
          "properties": {
            "companyName": { "type": "string" },
            "position": { "type": "string" },
            "yearsOfExperience": { "type": "integer", "minimum": 0 },
            "isPermanent": { "type": "boolean", "default": false }
          }
        }
      }
    },
    "financialInfo": {
      "type": "object",
      "required": ["monthlyIncome", "existingDebts"],
      "properties": {
        "monthlyIncome": { "type": "number", "exclusiveMinimum": 0 },
        "existingDebts": { "type": "number", "minimum": 0 },
        "currency": { "type": "string", "enum": ["IDR", "USD", "SGD"] }
      }
    },
    "assets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["assetType", "estimatedValue"],
        "properties": {
          "assetType": { "type": "string" },
          "estimatedValue": { "type": "number", "minimum": 0 }
        }
      }
    }
  }
}